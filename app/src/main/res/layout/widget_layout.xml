<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_background">

    <!-- Header row: bleeds to top/left/right edges -->
    <LinearLayout
        android:id="@+id/widget_header_row"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/widget_header"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/widget_title"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="6dp" />

        <TextView
            android:id="@+id/btn_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x21BA;"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="12dp"
            android:paddingEnd="4dp" />

    </LinearLayout>


    <!-- Top shadow (header casts onto list) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@drawable/shadow_top" />

    <!-- Scrollable monitor list -->
    <ListView
        android:id="@+id/monitor_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"
        android:divider="@null"
        android:dividerHeight="0dp" />

    <!-- Bottom shadow (footer casts onto list) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@drawable/shadow_bottom" />

    <!-- Footer row: separate background target -->
    <LinearLayout
        android:id="@+id/widget_footer_row"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/last_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:paddingTop="4dp"
            android:paddingBottom="6dp"
            android:paddingStart="14dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

</LinearLayout>
